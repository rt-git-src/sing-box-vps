{
  "log": { "level": "warn" },
  "dns": {
    "servers": [
      {
        "tag": "dns-custom",
        "type": "https",
        "server": "8.8.8.8"
      }
    ],
    "final": "dns-custom",
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "type": "hysteria2",
      "listen": "::",
      "listen_port": 443,
      "users": [
        {
	  "name": "REPLACE_ME",
          "password": "REPLACE_ME"
        }
      ],
      "tls": {
        "enabled": true,
        "alpn": [ "h3" ],
        "certificate_path": "/etc/letsencrypt/live/my.domain.com/fullchain.pem",
        "key_path": "/etc/letsencrypt/live/my.domain.com/privkey.pem"
      },
      "masquerade": "https://www.usa.gov"
    },
    {
      "type": "trojan",
      "listen": "0.0.0.0",
      "listen_port": 8443,
      "users": [
        {
          "name": "REPLACE_ME",
          "password": "REPLACE_ME"
        }
      ],
      "tls": {
        "enabled": true,
        "alpn": [ "h2", "h3" ],
        "certificate_path": "/etc/letsencrypt/live/my.domain.com/fullchain.pem",
        "key_path": "/etc/letsencrypt/live/my.domain.com/privkey.pem"
      },
      "transport": {
        "type": "grpc",
        "service_name": "api.Gateway",
        "idle_timeout": "15s",
        "ping_timeout": "15s",
        "permit_without_stream": false
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "type": "direct"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "dns-custom",
    "rule_set": [
      {
        "tag": "rules",
        "type": "local",
        "format": "binary",
        "path": "/var/lib/sing-box/rules.srs"
      }
    ],
    "rules": [
      { "action": "sniff" },
      { "outbound": "direct", "ip_is_private": true },
      { "action": "reject", "rule_set": "rules" }
    ],
    "final": "direct"
  },
  "experimental": {
    "cache_file": { "enabled": true }
  }
}

